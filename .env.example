# ============================================
# 电影院售票系统 - 环境变量配置
# 复制此文件为 .env 并修改为自己的配置
# ============================================

# MySQL 数据库 Root 密码（必填）
MYSQL_ROOT_PASSWORD=your_secure_password_here

# MySQL 数据库名（可选，默认 cinema_manager）
MYSQL_DATABASE=cinema_manager

# MySQL 端口（可选，默认 3306）
MYSQL_PORT=3306

# 后端 API 端口（可选，默认 9231）
BACKEND_PORT=9231

# 管理端前端端口（可选，默认 9233）
ADMIN_PORT=9233

# 用户端前端端口（可选，默认 9232）
USER_PORT=9232
